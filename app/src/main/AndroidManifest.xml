<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Runs the model server as a background/headless process without the
         app being in the foreground. Android requires this to surface as a
         persistent notification while active — that's not a limitation to
         work around, it's the thing that keeps a background process from
         being invisible spyware-style behavior. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Broad file access (models, project files anywhere on-device), the
         strongest storage permission a non-system app can hold on Android 11+.
         Requires the user to flip it on manually in Settings after install. -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />

    <!-- Declares intent to use UsageStatsManager (screen-time totals only -
         see UsageStatsHelper.kt's docstring for exactly what this can and
         cannot see). Like MANAGE_EXTERNAL_STORAGE, this is only grantable
         by the user manually in Settings, never via a runtime dialog. -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:theme="@style/Theme.PyBox"
        android:usesCleartextTraffic="true"
        android:requestLegacyExternalStorage="true">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Receives "Share" from Chrome (or any app) - a URL shared here
             opens directly in PyBox's own in-app browser, ready for you to
             extract data from with one tap. This is the sanctioned
             direction of Chrome integration: you explicitly send a page
             TO PyBox. PyBox never reads Chrome's own browsing silently. -->
        <activity
            android:name=".BrowserActivity"
            android:exported="true"
            android:label="PyBox Browser">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- Local-only browser for this app's own storage: contacts.db,
             usage_stats.db, encrypted backups, and anything imported into
             the PyBox folder. Does not request access to other apps'
             private storage. -->
        <activity
            android:name=".FileExplorerActivity"
            android:exported="false"
            android:label="File Explorer" />

        <activity
            android:name=".DbViewerActivity"
            android:exported="false"
            android:label="Database Viewer" />

        <activity
            android:name=".FileViewerActivity"
            android:exported="false"
            android:label="File Viewer" />

        <service
            android:name=".LlamaEngineService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="on-device local LLM inference server" />
        </service>
    </application>

</manifest>
